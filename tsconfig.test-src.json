{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "outDir": "dist-test",
    "rootDir": "src"
  },
  "include": [
    "src/bell.ts",
    "src/double-shift.ts",
    "src/pty-event-reducer.ts",
    "src/snippet-payload.ts",
    "src/types.ts"
  ]
}
